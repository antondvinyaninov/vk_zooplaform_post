---
import '../styles/global.css';
import { Button } from '@/components/ui/button';
import { ThemeToggle } from '@/components/ThemeToggle';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<title>Astro + shadcn/ui</title>
		
		<!-- Инлайн-скрипт предотвращает мерцание (FOUC) при загрузке страницы -->
		<script is:inline>
			const getThemePreference = () => {
				if (typeof localStorage !== 'undefined' && localStorage.getItem('theme')) {
					return localStorage.getItem('theme');
				}
				return window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
			};
			const isDark = getThemePreference() === 'dark';
			document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
		</script>
	</head>

	<body>
		<div class="absolute top-4 right-4">
			<ThemeToggle client:load />
		</div>
		
		<div class="grid place-items-center h-screen content-center gap-4">
			<h1 class="text-3xl font-bold">Hello, shadcn/ui!</h1>
			<Button client:load className="cursor-pointer">Click me!</Button>
		</div>
	</body>
</html>
