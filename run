#!/bin/bash

echo "🚀 Запуск VK SMM Панель (React + VKUI)..."

# Функция для освобождения порта
kill_port() {
    local port=$1
    local pid=$(lsof -ti:$port)
    if [ ! -z "$pid" ]; then
        echo "⚠️  Порт $port занят (PID: $pid), освобождаю..."
        kill -9 $pid 2>/dev/null
        sleep 1
    fi
}

# Проверка и очистка портов
echo "🔍 Проверка портов..."
kill_port 80
kill_port 3000
kill_port 5001
kill_port 5173

# Убиваем AirPlay на порту 5000 (macOS)
echo "🔧 Освобождение порта 5000 от AirPlay..."
lsof -ti:5000 | xargs kill -9 2>/dev/null || true
sleep 1

# Запуск Python VK Service
echo "🐍 Запуск VK Service (Python)..."
cd backend/vk_service
python3 main.py &
VK_SERVICE_PID=$!
cd ../..

# Ожидание запуска VK Service
sleep 2

# Запуск Go бэкенда
echo "📦 Запуск Go Backend (порт 80)..."
cd backend
if command -v air &> /dev/null; then
    echo "   Используется Air (hot reload)"
    air &
else
    echo "   Air не найден, используется go run"
    echo "   Установите Air для hot reload: go install github.com/cosmtrek/air@latest"
    go run main.go &
fi
BACKEND_PID=$!
cd ..

# Ожидание запуска бэкенда
sleep 2

# Запуск React фронтенда
echo "⚛️  Запуск React Frontend (Vite)..."
cd front-react
npm run dev &
FRONTEND_PID=$!
cd ..

echo ""
echo "✅ Приложение запущено!"
echo "   React Frontend: http://localhost:3000"
echo "   Go Backend:     http://localhost:80"
echo "   VK Service:     http://localhost:5001 (внутренний)"
echo ""
echo "Для остановки нажмите Ctrl+C"

# Обработка сигнала завершения
trap "echo ''; echo '🛑 Остановка...'; kill $FRONTEND_PID $BACKEND_PID $VK_SERVICE_PID 2>/dev/null; exit" INT TERM

# Ожидание
wait
