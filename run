#!/bin/bash

echo "🚀 Запуск VK ZooPlatforma..."

# Функция для освобождения порта
kill_port() {
    local port=$1
    local pid=$(lsof -ti:$port)
    if [ ! -z "$pid" ]; then
        echo "⚠️  Порт $port занят (PID: $pid), освобождаю..."
        kill -9 $pid 2>/dev/null
        sleep 1
    fi
}

# Проверка и очистка портов
echo "🔍 Проверка портов..."
kill_port 8000
kill_port 5173
kill_port 5174

# Запуск Go бэкенда
echo "📦 Запуск Go Backend (порт 8000)..."
cd backend

# Проверка наличия .env файла
if [ ! -f .env ]; then
    echo "⚠️  Файл .env не найден, копирую из .env.example..."
    cp .env.example .env
    echo "   ⚠️  Не забудьте настроить .env файл!"
fi

# Проверка наличия go.mod
if [ ! -f go.mod ]; then
    echo "❌ Файл go.mod не найден!"
    exit 1
fi

# Установка зависимостей если нужно
if [ ! -d "vendor" ]; then
    echo "📥 Установка Go зависимостей..."
    go mod download
fi

# Запуск с hot reload или обычный запуск
if [ -f ~/go/bin/air ]; then
    echo "   ✓ Используется Air (hot reload)"
    PORT=8000 ~/go/bin/air &
elif command -v air &> /dev/null; then
    echo "   ✓ Используется Air (hot reload)"
    PORT=8000 air &
else
    echo "   ℹ️  Air не найден, используется go run"
    echo "   💡 Установите Air для hot reload: go install github.com/air-verse/air@latest"
    PORT=8000 go run main.go &
    BACKEND_PID=$!
fi
cd ..

# Ожидание запуска бэкенда
echo "⏳ Ожидание запуска backend..."
sleep 3

# Проверка что backend запустился
if ! curl -s http://localhost:8000/api/health > /dev/null 2>&1; then
    echo "⚠️  Backend может быть еще не готов, продолжаем..."
fi

# Запуск VK Mini App
echo "⚛️  Запуск VK Mini App (Vite)..."
cd vk_app

# Проверка node_modules
if [ ! -d "node_modules" ]; then
    echo "📥 Установка npm зависимостей..."
    npm install
fi

npm run start &
VK_APP_PID=$!
cd ..

echo ""
echo "✅ Приложение запущено!"
echo "   📄 Админка:      http://localhost:8000"
echo "   🖥️  Go Backend:   http://localhost:8000/api"
echo "   📱 VK Mini App:  http://localhost:5173"
echo ""
echo "📚 Красивые URL:"
echo "   /               - Главная"
echo "   /auth           - Авторизация"
echo "   /groups         - Управление группами"
echo "   /posts          - Просмотр постов"
echo ""
echo "📚 API Endpoints:"
echo "   /api/health      - Health check"
echo "   /api/admin/*     - Admin API"
echo "   /api/app/*       - VK Mini App API"
echo "   /api/site/*      - Site API"
echo ""
echo "Для остановки нажмите Ctrl+C"

# Обработка сигнала завершения
trap "echo ''; echo '🛑 Остановка...'; kill $VK_APP_PID 2>/dev/null; pkill -f air 2>/dev/null; exit" INT TERM

# Ожидание
wait
